DATE_OPTIONS_HOUR=2-digit
DATE_OPTIONS_MINUTE=2-digit
DATE_OPTIONS_WEEKDAY=long
ENV_MESSAGE=
FRACTION_DIGITS_MAX=2
FRACTION_DIGITS_MIN=0
