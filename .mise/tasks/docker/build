#!/usr/bin/env bash
#MISE description="Build docker image"
#MISE depends="docker:prepare"
#USAGE flag "--clean" help="Prune buildx cache, disable cache and force pull latest base images"

set -e 

CLEAN_MODE="${usage_clean:-false}"

EXTRA_FLAGS=()
if [ "$CLEAN_MODE" = "true" ]; then
    echo "🧹 Clean-Mode aktiviert: Leere Docker Buildx Cache..."
    docker buildx prune -f
    
    echo "⬇️ Erzwinge Download der neuesten Base-Images..."
    # --pull zwingt Docker, online nach neueren Base-Images zu suchen
    # --no-cache ignoriert alle lokalen Build-Schritte und baut zu 100% neu
    EXTRA_FLAGS=("--pull" "--no-cache")
fi

echo "🚀 Building Docker image 'kasseapparat'..."

VERSION="0.0.$(date +%y%m%d%H%M)"
BUILD_DATE=$(date -Iseconds)

echo "📦 Version: $VERSION"
echo "📅 Build Date: $BUILD_DATE"

docker buildx build \
    --builder kasseapparat-builder \
    --build-arg VERSION="$VERSION" \
    --build-arg BUILD_DATE="$BUILD_DATE" \
    --tag kasseapparat:latest \
    --tag "kasseapparat:$VERSION" \
    "${EXTRA_FLAGS[@]}" \
    --load \
    .

echo "✅ Docker image 'kasseapparat:latest' built successfully!"