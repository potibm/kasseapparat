#!/usr/bin/env bash
#MISE description="Lint frontend code (pass --fix to auto-fix)"
#MISE dir="{{cwd}}/frontend"
#USAGE flag "--fix" help="Automatically fix linting issues"

set -e

FIX_MODE="${usage_fix:-false}"

echo "🎨 Frontend (Auto-Fix: $FIX_MODE)"
if [ "$FIX_MODE" = "true" ]; then
    prettier . --write
    corepack yarn run eslint --fix
    dotenv-linter fix . --no-backup
    corepack yarn run tsc --noEmit
else
    corepack yarn run tsc --noEmit
    corepack yarn run eslint
    prettier . --check
    dotenv-linter check .
fi